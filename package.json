{
  "name": "aumveda",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "prisma generate --schema=packages/db/prisma/schema.prisma && cd apps/web && npx next build",
    "start": "cd apps/web && npx next start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/db/prisma/schema.prisma",
    "db:seed": "cd packages/db && npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
    ]
  }
}
