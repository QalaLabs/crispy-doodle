# ─── DATABASE ───────────────────────────────────────────────────────────────
# Neon.tech or Supabase PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/aumveda?sslmode=require"

# ─── AUTH (NextAuth.js) ──────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (magic link / verification) — use Resend, Nodemailer, or SendGrid
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@aumveda.com"

# ─── CLOUDFLARE R2 (Object Storage) ─────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="aumveda-assets"
CLOUDFLARE_R2_PUBLIC_URL="https://assets.aumveda.com"

# ─── CASHFREE (Payments) ─────────────────────────────────────────────────────
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_WEBHOOK_SECRET=""
# "sandbox" or "production"
CASHFREE_ENV="sandbox"

# ─── OPENAI (AI Tips) ────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── PINECONE (Vector DB) ────────────────────────────────────────────────────
PINECONE_API_KEY=""
PINECONE_INDEX_NAME="aumveda-journals"

# ─── UPSTASH REDIS (BullMQ + Rate Limiting) ──────────────────────────────────
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# ─── API SERVER ──────────────────────────────────────────────────────────────
API_URL="http://localhost:3001"
# Internal secret used by web app to call API
API_INTERNAL_SECRET="generate-with: openssl rand -base64 32"

# ─── COURSES (JWT signing) ───────────────────────────────────────────────────
COURSE_JWT_SECRET="generate-with: openssl rand -base64 32"

# ─── HEALTH SYNC ─────────────────────────────────────────────────────────────
# AES-256 key for encrypting Google Fit refresh tokens (32 bytes, hex)
AES_ENCRYPTION_KEY="generate-with: openssl rand -hex 32"

# ─── GOOGLE TAG MANAGER ──────────────────────────────────────────────────────
GTM_CONTAINER_ID="GTM-XXXXXXX"
GTM_SERVER_URL="https://api.aumveda.com/gtm"

# Meta Conversions API
META_PIXEL_ID=""
META_ACCESS_TOKEN=""

# GA4 Measurement Protocol
GA4_MEASUREMENT_ID=""
GA4_API_SECRET=""

# Pinterest Conversions
PINTEREST_AD_ACCOUNT_ID=""
PINTEREST_ACCESS_TOKEN=""

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
